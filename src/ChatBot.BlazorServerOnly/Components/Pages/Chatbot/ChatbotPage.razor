@page "/"
<main class="chat-page">
    <LeftSidebar @ref="_leftSidebar" UserId="@_userId" OnNewChat="NewChat" OnConversationSelected="SwitchSession" />
    <div class="chat-main">
        <section class="chat-messages">
            <div class="message-list">
                @foreach (ConversationMessage message in _conversation.Messages)
                {
                    if (message.Role == ChatRole.User)
                    {
                        <UserMessage Message="message" />
                    }
                    else if (message.Role == ChatRole.Assistant)
                    {
                        <AssistantReasoningResponse Contents="message.Contents" />
                        <AssistantToolCallResponse Contents="message.Contents" Conversation="_conversation" />
                        <AssistantTextResponse Message="message" />
                        <AssistantImageResponse Message="message"/>
                    }
                }

                <MidTurnVisuals Streaming="_streaming"
                                InImageGenerationMode="_inImageGenerationMode"
                                Conversation="_conversation"
                                StreamedContents="_streamedContent"
                                StreamedResponse="@_streamedResponse"
                                StreamedReasoning="@_streamedReasoning" />
                
                @if (_memoryUpdate != null)
                {
                    <article class="message-row from-assistant">
                        <p class="meta-info" style="color: maroon">@_memoryUpdate.GetDisplayString()</p>
                    </article>
                }
            </div>
        </section>

        <form class="composer" @onsubmit="SendAsync">
            @if (_pendingFiles.Count > 0)
            {
                <div class="pending-attachments">
                    @foreach (PendingAttachment file in _pendingFiles)
                    {
                        <div class="attachment-thumbnail" title="@file.FileName">
                            @if (file.PreviewDataUri is not null)
                            {
                                <img src="@file.PreviewDataUri" alt="@file.FileName" />
                            }
                            else
                            {
                                <span>PDF</span>
                            }
                        </div>
                    }
                </div>
            }
            <div class="composer-controls">
                <label class="file-upload-button" title="Attach files">
                    +
                    <InputFile class="file-upload-input"
                               OnChange="SelectFilesAsync"
                               accept="application/pdf,image/*"
                               multiple />
                </label>
                <textarea @bind="_input"
                          @bind:event="oninput"
                          rows="3"
                          placeholder="Type a message..."
                          onkeydown="if (event.key === 'Enter' && !event.shiftKey) { event.preventDefault(); document.getElementById('send-message-button').click(); }"
                          class="message-input"></textarea>
                <button id="send-message-button" class="send-button" type="submit">Send</button>
            </div>
        </form>
    </div>
    <RightSidebar Streaming="_streaming"
                  UserId="@_userId"
                  StreamingChanged="SetStreamingAsync"
                  SelectedImageGenStyle="_imageGenStyle"
                  SelectedImageGenStyleChanged="SetImageGenStyleAsync" />
</main>
