@page "/"
@using ChatBot.BlazorServerOnly.Extensions
@using Microsoft.Agents.AI
@using Microsoft.Extensions.AI

<PageTitle>Blazor Server Chatbot</PageTitle>

<main class="chat-page">
    <aside class="conversation-sidebar">
        <button class="new-chat-button" type="button" @onclick="NewChatAsync">New Chat</button>

        <div class="conversation-list">
            @foreach (AgentSession session in _previousSessions)
            {
                <button class="conversation-button" type="button" @onclick="() => SwitchSession(session)">@(session.StateBag.GetValue<string>("title"))</button>
            }
        </div>
    </aside>

    <div class="chat-main">
        <section class="chat-messages">
            <div class="message-list">

                @if (_currentSession?.TryGetInMemoryChatHistory(out List<ChatMessage>? messages) == true)
                {
                    @foreach (ChatMessage message in messages)
                    {
                        if (message.Role == ChatRole.User)
                        {
                            <article class="message-row from-user">
                                <div class="message-bubble">
                                    <p class="message-text">@message.Text</p>
                                </div>
                            </article>
                        }
                        else if (message.Role == ChatRole.Assistant)
                        {
                            foreach (AIContent content in message.Contents)
                            {
                                if (content is FunctionCallContent functionCallContent)
                                {
                                    <article class="message-row from-assistant">
                                        <p class="meta-info">Tool Call Request: @functionCallContent.AsDisplayString()</p>
                                    </article>
                                }
                                else if (content is TextReasoningContent textReasoningContent && !string.IsNullOrWhiteSpace(textReasoningContent.Text))
                                {
                                    <article class="message-row from-assistant">
                                        <p class="meta-info">Thoughts: @textReasoningContent.Text</p>
                                    </article>
                                }
                            }

                            @if (!string.IsNullOrWhiteSpace(message.Text))
                            {
                                <article class="message-row from-assistant">
                                    <div class="message-bubble">
                                        <p class="message-text">@message.Text</p>
                                    </div>
                                </article>
                            }
                        }
                        else if (message.Role == ChatRole.Tool)
                        {
                            @foreach (AIContent content in message.Contents)
                            {
                                if (content is FunctionResultContent functionResultContent)
                                {
                                    <article class="message-row from-assistant">
                                        <p class="meta-info">Tool Call Result: @functionResultContent.AsDisplayString()</p>
                                    </article>
                                }
                            }

                        }
                    }
                }

                @if (_currentPrompt != null)
                {
                    <article class="message-row from-user">
                        <div class="message-bubble">
                            <p class="message-text">@_currentPrompt</p>
                        </div>
                    </article>

                    @if (!_streaming)
                    {
                        <article class="message-row from-assistant">
                            <div class="message-bubble">
                                <p class="message-text">...</p>
                            </div>
                        </article>
                    }
                }

                @if (_streamedReasoning != null)
                {
                    <article class="message-row from-assistant">
                        <p class="meta-info">Thoughts: @_streamedReasoning</p>
                    </article>
                }

                @foreach (AIContent content in _streamedContent)
                {
                    switch (content)
                    {
                        case FunctionCallContent functionCallContent:
                            <article class="message-row from-assistant">
                                <p class="meta-info">Tool Call Request: @functionCallContent.AsDisplayString()</p>
                            </article>

                            break;
                        case FunctionResultContent functionResultContent:
                            <article class="message-row from-assistant">
                                <p class="meta-info">Tool Call Result: @functionResultContent.AsDisplayString()</p>
                            </article>
                            break;
                    }
                }

                @if (!string.IsNullOrEmpty(_streamedResponse))
                {
                    <article class="message-row from-assistant">
                        <div class="message-bubble">
                            <p class="message-text">@_streamedResponse</p>
                        </div>
                    </article>
                }
            </div>
        </section>

        <form class="composer" @onsubmit="SendMessageAsync">
            <textarea @bind="_input"
                      @bind:event="oninput"
                      rows="3"
                      placeholder="Type a message..."
                      onkeydown="if (event.key === 'Enter' && !event.shiftKey) { event.preventDefault(); document.getElementById('send-message-button').click(); }"
                      class="message-input"></textarea>
            <button id="send-message-button" class="send-button" type="submit">Send</button>
        </form>
    </div>

    <aside class="options-sidebar">
        <h2 class="options-title">Options</h2>
        <label class="option-check">
            <input class="option-checkbox" type="checkbox" @bind="_streaming" />
            <span>Streaming</span>
        </label>

        @if (_usageDetails != null)
        {
            <br />
            <h2 class="options-title">Stats (for last turn)</h2>

            <p class="meta-info" style="font-size: 11px">Input tokens: @_usageDetails.InputTokenCount</p>
            <p class="meta-info" style="font-size: 11px">Output tokens: @_usageDetails.OutputTokenCount</p>
            <p class="meta-info" style="font-size: 11px">Reasoning tokens: @_usageDetails.ReasoningTokenCount</p>
        }
    </aside>
</main>
