@page "/"
@using Microsoft.Agents.AI
@using Microsoft.Extensions.AI

<PageTitle>Blazor Server Chatbot</PageTitle>


<main style="display: flex; flex-direction: column; height: 100vh; background: #ffffff; color: #1f2937; font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;">
    <section aria-label="Chat messages" style="flex: 1; overflow-y: auto; padding: 24px; background: #f8fafc;">
        <div style="display: flex; flex-direction: column; gap: 14px; max-width: 960px; margin: 0 auto;">

            @if (_session?.TryGetInMemoryChatHistory(out List<ChatMessage>? messages) == true)
            {
                @foreach (ChatMessage message in messages)
                {
                    bool isUser = message.Role == ChatRole.User;

                    <article style="display: flex; justify-content: @(isUser ? "flex-end" : "flex-start");">
                        <div style="max-width: min(680px, 82%); padding: 12px 14px; border-radius: 14px; background: @(isUser ? "#2563eb" : "#ffffff"); color: @(isUser ? "#ffffff" : "#111827"); border: 1px solid @(isUser ? "#2563eb" : "#e5e7eb"); box-shadow: 0 1px 2px rgba(15, 23, 42, 0.08);">
                            <p style="margin: 0; white-space: pre-wrap; overflow-wrap: anywhere; line-height: 1.45;">@message.Text</p>
                        </div>
                    </article>
                }
            }
        </div>
    </section>

    <form @onsubmit="SendMessageAsync" style="display: flex; gap: 12px; align-items: flex-end; width: 100%; box-sizing: border-box; padding: 16px 24px; border-top: 1px solid #e5e7eb; background: #ffffff;">
        <textarea @bind="_input"
                  @bind:event="oninput"
                  rows="3"
                  placeholder="Type a message..."
                  aria-label="Message input"
                  onkeydown="if (event.key === 'Enter' && !event.shiftKey) { event.preventDefault(); document.getElementById('send-message-button').click(); }"
                  style="flex: 1 1 auto; min-width: 0; min-height: 72px; max-height: 180px; resize: vertical; box-sizing: border-box; border: 1px solid #d1d5db; border-radius: 12px; padding: 12px 14px; color: #111827; background: #ffffff; font: inherit; line-height: 1.4; outline-color: #2563eb;"></textarea>
        <button id="send-message-button" type="submit" style="align-self: stretch; flex: 0 0 auto; min-width: 88px; border: 0; border-radius: 12px; padding: 0 18px; background: #111827; color: #ffffff; font: inherit; font-weight: 600; cursor: pointer;">Send</button>
    </form>
</main>
